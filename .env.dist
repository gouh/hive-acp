# Copy to .env and fill in your values:  cp .env.dist .env

# Telegram bot token (get it from @BotFather: https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Absolute path to kiro-cli binary (find with: which kiro-cli)
KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Directory where the AI agent will read/write files
KIRO_WORKSPACE=/home/ubuntu/my-project

# Telegram user IDs allowed to interact with the bot (comma-separated)
# Get your ID from @userinfobot — leave empty to allow everyone (not recommended)
ALLOWED_USERS=

# Agent name matching a file in <workspace>/.kiro/agents/<name>.json
# KIRO_AGENT=my-agent
