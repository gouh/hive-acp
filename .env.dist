# Copy to .env and fill in your values:  cp .env.dist .env

# ── General ──────────────────────────────────────────────────
# Directory where the AI agent will read/write files
HIVE_WORKSPACE=/home/ubuntu/my-project

# WebSocket MCP server port
HIVE_MCP_PORT=4040

# Log level (debug, info, warn, error)
HIVE_LOG_LEVEL=info

# ── Orchestrator ──────────────────────────────────────────────
# Agent name to use as the main orchestrator (must be registered in the registry)
# Kiro agents: auto-discovered from ~/.kiro/agents/
# OpenCode agents: registered in ~/.hive-acp/agents.json
HIVE_ORCHESTRATOR=hiveacp-orchestrator

# ── Kiro ─────────────────────────────────────────────────────
# Absolute path to kiro-cli binary (find with: which kiro-cli)
HIVE_KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Agent name matching a file in <workspace>/.kiro/agents/<name>.json
# HIVE_KIRO_AGENT=my-agent

# ── OpenCode ─────────────────────────────────────────────────
# Absolute path to opencode binary (find with: which opencode)
# HIVE_OPENCODE_CLI_PATH=/usr/local/bin/opencode

# ── Telegram ─────────────────────────────────────────────────
# Telegram bot token (get it from @BotFather: https://t.me/BotFather)
HIVE_TELEGRAM_TOKEN=

# Telegram user IDs allowed to interact with the bot (comma-separated)
# Get your ID from @userinfobot — leave empty to allow everyone (not recommended)
HIVE_ALLOWED_USERS=

# ── Pexels ───────────────────────────────────────────────────
# API key for free stock photo search (get it from https://www.pexels.com/api/)
# HIVE_PEXELS_KEY=