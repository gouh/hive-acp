# ============================================
# Kiro ACP Telegram Bot — Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# REQUIRED: Telegram Bot Token
# Get from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-token-here

# Path to kiro-cli binary
# Find with: which kiro-cli
KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Workspace directory for Kiro to operate in
KIRO_WORKSPACE=/home/ubuntu/my-project

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot on Telegram
# Leave empty to allow all users (not recommended for production)
ALLOWED_USERS=123456789

# Optional: custom agent name
# Must match a file in <workspace>/.kiro/agents/<name>.json
# KIRO_AGENT=my-agent
